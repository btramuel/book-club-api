// ==
//
// 1. Purpose
//    This file defines the database schema for the Book Club API.
//    Prisma reads it to generate the database tables and the
//    PrismaClient types used throughout the codebase. Every model
//    here maps directly to a table in PostgreSQL.
//
// 2. Key Terms and Definitions
//    model: a Prisma keyword that defines one database table and all its fields
//    @id: marks a field as the primary key
//
//    @default(uuid()): tells Prisma to auto-generate a UUID when a new row is inserted
//
//    @unique: adds a unique constraint so no two rows can have the same value in that column
//
//    @relation: defines a foreign key relationship between two models
//
//    onDelete: Cascade: if the parent row is deleted, all related child rows are automatically deleted too.
//    Used on club_members and reading_lists so deleting a club cleans everything up
//
//    @@unique([a, b]): a compound unique constraint across two fields. Used on club_members so a user can only join
//    a club once, and on reading_lists so a book can only appear once per club
//
//    @@map("table"): sets the actual PostgreSQL table name since, Prisma model names are PascalCase by convention
//
// 3. Inputs
//    - DATABASE_URL in .env → tells Prisma which database to connect to
//
// 4. Output
//    Running prisma migrate dev generates the SQL and creates the
//    actual tables in PostgreSQL. Running prisma generate creates
//    the typed PrismaClient used in repositories/prisma.js.
//
// Plan
//
// 1. Configure the generator to use prisma client-js
// 2. Configure the datasource to use PostgreSQL and read the URL from the DATABASE_URL environment variable
// 3. Define the User model — accounts with unique email and username
// 4. Define the Book model — titles with optional ISBN, genre, pageCount
// 5. Define the Club model — owned by a user, optionally private
// 6. Define the ClubMember model — junction table linking users to clubs
//    with a compound unique constraint to prevent duplicate memberships
// 7. Define the ReadingList model — links a book to a club with a status
//    and optional start and finish dates
// ==

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  // Relations
  ownedClubs  Club[]       @relation("ClubOwner")
  memberships ClubMember[]

  @@map("users")
}

model Book {
  id        String   @id @default(uuid())
  title     String
  author    String
  isbn      String?  @unique
  genre     String?
  pageCount Int?
  createdAt DateTime @default(now())

  // Relations
  readingListEntries ReadingList[]

  @@map("books")
}

model Club {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  description String?
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Relations
  owner        User          @relation("ClubOwner", fields: [ownerId], references: [id])
  members      ClubMember[]
  readingLists ReadingList[]

  @@map("clubs")
}

model ClubMember {
  id       String   @id @default(uuid())
  clubId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  // Relations
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@map("club_members")
}

model ReadingList {
  id         String    @id @default(uuid())
  clubId     String
  bookId     String
  status     String    @default("planned")
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id])

  @@unique([clubId, bookId])
  @@map("reading_lists")
}